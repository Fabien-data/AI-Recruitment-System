# ═══════════════════════════════════════════════════════════════════════════
# WhatsApp Recruitment Chatbot — Environment Configuration
# Copy this file to .env and fill in all values before deploying.
# ⚠️  NEVER commit the real .env file to version control.
# ═══════════════════════════════════════════════════════════════════════════

# ── Meta WhatsApp Business API ──────────────────────────────────────────────
META_ACCESS_TOKEN=your_system_user_permanent_token_here
META_WHATSAPP_BUSINESS_ACCOUNT_ID=your_waba_id_here
META_PHONE_NUMBER_ID=your_production_phone_number_id_here
META_APP_SECRET=your_meta_app_secret_here
META_VERIFY_TOKEN=replace_with_strong_random_verify_token
META_API_VERSION=v18.0

# IMPORTANT:
# 1) Generate access token from Meta Business Manager -> System Users (permanent token)
# 2) Keep App Mode = Live in Meta Developers (Dev mode only receives test webhooks)
# 3) Callback URL must be: {CLOUD_RUN_URL}/webhook/whatsapp

# ── OpenAI (used for GPT-4o-mini + embeddings — REQUIRED) ───────────────────
OPENAI_API_KEY=sk-proj-REPLACE_WITH_YOUR_KEY

# ── Pinecone (OPTIONAL — leave blank to use MySQL FULLTEXT search fallback) ──
# If blank, the RAG engine automatically uses keyword search from the DB.
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=recruitment-kb

# ── MySQL Database — Serverbyt ───────────────────────────────────────────────
# Both the chatbot and the recruitment system share the same MySQL server.
# Create a dedicated database: e.g. youraccount_chatbot
DATABASE_URL=mysql+pymysql://db_user:db_password@localhost/youraccount_chatbot
DB_HOST=localhost
DB_PORT=3306
DB_NAME=youraccount_chatbot
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# ── Integration with Recruitment System ─────────────────────────────────────
# The URL where the Node.js recruitment backend is running.
# On Serverbyt this is typically your subdomain or passenger-routed path.
RECRUITMENT_API_URL=https://api.yourdomain.com
CHATBOT_API_KEY=generate_a_strong_random_secret_here_min32chars
RECRUITMENT_SYNC_ENABLED=true

# ── Deployment URL (used for webhook callback generation) ───────────────────
CLOUD_RUN_URL=https://your-chatbot-service-url.run.app

# ── Redis (OPTIONAL — app works without it; sessions stored in DB) ───────────
REDIS_URL=

# ── Application Settings ─────────────────────────────────────────────────────
APP_NAME=Dewan Recruitment Chatbot
DEBUG=false
LOG_LEVEL=INFO

# ── File Storage ─────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ── Company Information ───────────────────────────────────────────────────────
COMPANY_NAME=Dewan Consultants
COMPANY_WEBSITE=https://yourdomain.com
