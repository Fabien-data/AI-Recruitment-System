# Copy this file to .env and fill with real values
# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=recruitment_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# Toggle database modes
USE_MYSQL=false
USE_SUPABASE_DB=false

# Optional: user ID to set as created_by when seeding jobs
SEED_CREATED_BY=

# CORS origin for frontend development
CORS_ORIGIN=http://localhost:5173

# Uploads directory (relative to project root)
UPLOAD_DIR=./uploads
