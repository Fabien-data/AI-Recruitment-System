# Server Configuration
PORT=3000
NODE_ENV=development

# ===========================================
# n8n Integration Settings
# ===========================================
# Set to 'true' to use n8n for email/WhatsApp processing
# When enabled, the backend only serves dashboard API
USE_N8N_FOR_EMAIL=true

# ===========================================
# Database Configuration
# ===========================================
# Option 1: Supabase (Recommended for n8n integration)
USE_SUPABASE_DB=true
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://postgres:[password]@db.[project-id].supabase.co:5432/postgres

# Option 2: Google Cloud SQL (PostgreSQL) — Recommended for Cloud Run
# USE_CLOUD_SQL=true
# Format: PROJECT_ID:REGION:INSTANCE_NAME  (e.g. my-project:us-central1:recruitment-db)
# CLOUD_SQL_INSTANCE_CONNECTION_NAME=your-project-id:us-central1:recruitment-db
# CLOUD_SQL_USER=recruitment_user
# CLOUD_SQL_PASSWORD=your_db_password
# CLOUD_SQL_DATABASE=recruitment_db
# On Cloud Run these are injected automatically via Unix socket.
# For local dev, run: cloud-sql-proxy PROJECT:REGION:INSTANCE --port=5432
# then set DB_HOST=127.0.0.1 and the CLOUD_SQL_* vars above.

# Option 3: Local PostgreSQL (Legacy/Development)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=recruitment_db
DB_USER=postgres
DB_PASSWORD=your_password

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# WhatsApp Configuration
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_access_token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token

# Messenger Configuration
MESSENGER_PAGE_ACCESS_TOKEN=your_page_access_token
MESSENGER_VERIFY_TOKEN=your_verify_token
MESSENGER_APP_SECRET=your_app_secret

# Gmail API Configuration
GMAIL_CLIENT_ID=your_client_id
GMAIL_CLIENT_SECRET=your_client_secret
GMAIL_REDIRECT_URI=your_redirect_uri

# Google Vision API
GOOGLE_APPLICATION_CREDENTIALS=path/to/credentials.json
GOOGLE_VISION_ENABLED=true

# SMS Configuration (Notify.lk)
NOTIFY_LK_API_KEY=your_api_key
NOTIFY_LK_USER_ID=your_user_id

# Camb.ai Configuration
CAMB_AI_API_KEY=your_api_key

# ElevenLabs Configuration
ELEVENLABS_API_KEY=your_api_key

# 3CX Configuration
THREE_CX_URL=your_3cx_url
THREE_CX_API_KEY=your_api_key

# JWT Secret
JWT_SECRET=your_jwt_secret_key

# File Storage (local = save to UPLOAD_DIR)
STORAGE_TYPE=local
UPLOAD_DIR=./uploads
# or use R2
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=your_bucket_name

# Google Calendar
GOOGLE_CALENDAR_ID=your_calendar_id
