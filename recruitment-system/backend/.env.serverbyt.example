# Recruitment System Backend - Serverbyt Production Environment
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

PORT=3000
NODE_ENV=production

# Database - Serverbyt MySQL
USE_MYSQL=true
USE_SUPABASE_DB=false
DB_HOST=localhost
DB_PORT=3306
DB_NAME=youraccount_recruitment
DB_USER=youraccount_dbuser
DB_PASSWORD=your_strong_db_password
DB_SSL=false

# WhatsApp Business API
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=dewan_recruitment_webhook_2024

# OpenAI
OPENAI_API_KEY=sk-proj-REPLACE_WITH_YOUR_KEY
OPENAI_MODEL=gpt-4o-mini

# JWT
JWT_SECRET=REPLACE_with_64_char_random_string

# Chatbot Integration
CHATBOT_API_KEY=REPLACE_with_strong_shared_secret
CHATBOT_API_URL=https://chatbot.yourdomain.com

# Gmail Integration
GMAIL_CLIENT_ID=your_gmail_oauth_client_id
GMAIL_CLIENT_SECRET=your_gmail_oauth_client_secret
GMAIL_REDIRECT_URI=https://api.yourdomain.com/api/gmail/callback
USE_N8N_FOR_EMAIL=false

# SMS via Notify.lk
NOTIFY_LK_API_KEY=your_notifylk_api_key
NOTIFY_LK_USER_ID=your_notifylk_user_id

# Google Vision OCR (optional)
GOOGLE_VISION_ENABLED=false
GOOGLE_APPLICATION_CREDENTIALS=

# CORS
CORS_ORIGIN=https://yourdomain.com
FRONTEND_URL=https://yourdomain.com

# File Storage
STORAGE_TYPE=local
UPLOAD_DIR=./uploads
