# Server Configuration
PORT=3000
NODE_ENV=production
FRONTEND_URL=https://yourdomain.serverbyt.com

# ===========================================
# MySQL Database Configuration (Serverbyt)
# ===========================================
# USE_MYSQL=true activates MySQL mode
USE_MYSQL=true
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_username
DB_PASSWORD=your_password
DB_SSL=false

# For external MySQL (PlanetScale, etc.)
# DB_HOST=aws.connect.psdb.cloud
# DB_SSL=true

# ===========================================
# Legacy PostgreSQL (disabled for Serverbyt)
# ===========================================
# USE_SUPABASE_DB=false
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_KEY=

# ===========================================
# API Keys and Integrations
# ===========================================
# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# WhatsApp Configuration
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_access_token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token

# Messenger Configuration
MESSENGER_PAGE_ACCESS_TOKEN=your_page_access_token
MESSENGER_VERIFY_TOKEN=your_verify_token
MESSENGER_APP_SECRET=your_app_secret

# Google Vision API (for OCR)
GOOGLE_APPLICATION_CREDENTIALS=path/to/credentials.json
GOOGLE_VISION_ENABLED=true

# JWT Secret
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# File Storage
STORAGE_TYPE=local
UPLOAD_DIR=./uploads
# For cloud storage (optional)
# R2_ACCOUNT_ID=your_account_id
# R2_ACCESS_KEY_ID=your_access_key
# R2_SECRET_ACCESS_KEY=your_secret_key
# R2_BUCKET_NAME=your_bucket_name
