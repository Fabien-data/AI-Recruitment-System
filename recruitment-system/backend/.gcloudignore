# Ignore node_modules — Cloud Build installs them during build
node_modules/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local env files (secrets must be set via Cloud Run env vars)
.env
.env.local
.env.*.local

# Dev/test files
coverage/
.nyc_output/
tests/
test/
__tests__/
*.test.js
*.spec.js
jest.config.js

# OS / Editor files
.DS_Store
Thumbs.db
.vscode/
.idea/

# Uploads dir (large files, not needed in image)
uploads/

# Git
.git/
.gitignore
